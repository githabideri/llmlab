# Copy this file to scripts/forensics/.env (gitignored) and customize.

# Label used in reports (do not put secrets here)
FORENSICS_TAG=host-a

# Where samplers and snapshots write data
FORENSICS_OUTDIR=/var/log/forensics

# systemd units
GPU_SAMPLER_UNIT=gpu-sampler.service
FREEZE_TIMER_UNIT=freeze-sample.timer
BOOT_SNAPSHOT_UNIT=crash-snapshot.service
MODEL_SERVICE_UNIT=llama-server.service

# Health endpoint for model service
MODEL_HEALTH_URL=http://127.0.0.1:8080/health
