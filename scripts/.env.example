# fetch_model_info.py configuration
# Copy to .env and adjust for your setup.

# HuggingFace token (optional, for gated models)
# HF_TOKEN=hf_xxx

# KV cache quantization — bytes per element
# Adjust to match your llama-server --cache-type-k / --cache-type-v
KV_CACHE_K_BYTES=1.0    # q8_0 = 1 byte
KV_CACHE_V_BYTES=0.5    # q4_0 = 0.5 bytes

# Minimum context window to consider a model viable
MIN_CONTEXT=100000
