# Context Ladder Configuration
# Copy this to .env and customize for your setup

# Inference endpoint (llama.cpp server)
LLAMA_ENDPOINT=http://192.168.0.27:8080/v1/completions

# SSH host for monitoring (must have nvidia-smi and ps available)
LLAMA_SSH_HOST=llama-cpp

# Model name (for output files)
MODEL_NAME=Qwen3.5-35B-Q4_K_M

# Output directory for results
OUTPUT_DIR=results

# Process name to monitor (default: llama-server)
# PROCESS_NAME=llama-server
